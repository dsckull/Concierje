# ──────────────────────────────────────────────────────────────
# 🔧 VARIÁVEIS DE AMBIENTE - Condo Manager
# ──────────────────────────────────────────────────────────────

# 🚀 Server Configuration
NODE_ENV=production
PORT=5000

# 🌐 Frontend Configuration
BASE_PATH=/
VITE_API_BASE=https://your-app-name.up.railway.app

# 💾 Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[password]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres

# ⚡ Optional: Direct Database URL (use if Pooler causes issues)
# DATABASE_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres

# 🔐 Supabase Configuration (if needed for direct integration)
SUPABASE_URL=https://[project-id].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# 📝 Logging
LOG_LEVEL=info
